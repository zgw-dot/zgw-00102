{
  "app_name": "myapp",
  "version": "3.0.0",
  "features": {
    "auth": true,
    "notifications": true,
    "dark_mode": true,
    "analytics": true,
    "new_feature": true
  },
  "database": {
    "host": "db.example.com",
    "port": 5432,
    "name": "myapp_prod",
    "pool_size": 30,
    "timeout": 30
  },
  "api_endpoints": [
    {
      "path": "/api/v1/users",
      "method": "GET",
      "rate_limit": 300
    },
    {
      "path": "/api/v1/orders",
      "method": "POST",
      "rate_limit": 150
    },
    {
      "path": "/api/v2/analytics",
      "method": "GET",
      "rate_limit": 100
    },
    {
      "path": "/api/v3/new-feature",
      "method": "POST",
      "rate_limit": 50
    }
  ],
  "metadata": {
    "description": "Version 3 with new feature",
    "team": "platform",
    "release_date": "2026-06-15"
  }
}
